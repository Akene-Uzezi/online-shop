<form action="<%= submitPath %>?_csrf=<%= locals.csrfToken %>" method="POST" enctype="multipart/form-data">
    <p>
        <label for="title">Title</label>
        <input type="text" name="title" value="<%= product.title %>" id="title" required>
    </p>
    <p>
        <label for="image">Image</label>
        <input type="file" name="image" id="image" accept="image/png, image/jpg">
    </p>
    <p>
        <label for="summary">summary</label>
        <input type="text" name="summary" id="summary" value="<%= product.summary %>" required maxlength="250">
    </p>
    <p>
        <label for="price">Price</label>
        <input type="number" name="price" id="price" min="0.01" step="0.01" required value="<%= product.price %>">
    </p>
    <p>
        <label for="description">Description</label>
        <textarea type="text" name="description" id="description" required
            rows="7"><%= product.description %></textarea>
    </p>
    <p>
        <button type="reset" class="btn-alt">Reset</button>
        <button class="btn">Submit</button>
    </p>
</form>